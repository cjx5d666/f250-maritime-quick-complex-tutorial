# Source or adapt this file before running the F250 tutorial scripts.

export F250_PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
export F250_PX4_ROOT="/path/to/PX4-Autopilot"
export MAP_AUTHORITY="${F250_PROJECT_ROOT}/data/map_authority/p0_p8_hard_requirement_20260530"
export RUN_ROOT="${F250_PROJECT_ROOT}/runs/f250_human_scripts"
export CURRENT_STATUS="${RUN_ROOT}/current/status.env"

export ROS_DISTRO="${ROS_DISTRO:-noetic}"
export ROS_MASTER_URI="${ROS_MASTER_URI:-http://localhost:11311}"
export ENABLE_RVIZ="${ENABLE_RVIZ:-true}"
export PX4_GUI="${PX4_GUI:-true}"
export DISPLAY="${DISPLAY:-:0}"
